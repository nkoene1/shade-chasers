# Copy to `.env.local` and fill in from your Supabase project (Settings > API).
# The anon key is safe to expose in the Vite build; the service role key must
# only exist in the Supabase dashboard / Edge Function secrets — never in the app.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
